# --- Cách khuyến nghị: API key trên server (không lộ trong bundle client) ---
# Lấy tại https://www.metered.ca/dashboard → TURN Server → Create Credential
# App name = subdomain trước .metered.live (vd: myapp → https://myapp.metered.live/...)

METERED_API_KEY=your_api_key_here
METERED_APP_NAME=your_app_subdomain
# Tuỳ chọn: us_east, europe, asia, singapore, ...
# METERED_REGION=global

# --- Hoặc credential cố định (chỉ client, file client/.env) ---
# VITE_METERED_TURN_USERNAME=...
# VITE_METERED_TURN_CREDENTIAL=...

# --- Hoặc API key trực tiếp khi dev (client/.env) ---
# VITE_METERED_API_KEY=...
# VITE_METERED_APP_NAME=...
# VITE_METERED_REGION=global

# URL signaling khi build production (tuỳ chọn)
# VITE_SERVER_URL=https://your-domain.com
